{
  "publisher": "maxdewald",
  "name": "modelprovider",
  "displayName": "CLIProxyAPI Model Provider",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "volta": {
    "node": "24.16.0",
    "pnpm": "11.6.0"
  },
  "description": "Expose CLIProxyAPI models in GitHub Copilot Chat.",
  "author": "Maximilian Dewald <maximilian@dewald.one>",
  "license": "MIT",
  "homepage": "https://github.com/maxdewald/modelprovider#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxdewald/modelprovider.git"
  },
  "bugs": {
    "url": "https://github.com/maxdewald/modelprovider/issues"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.cjs",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "dist/*",
    "res/*"
  ],
  "engines": {
    "node": ">=22.18.0",
    "vscode": "^1.124.0"
  },
  "enabledApiProposals": [
    "chatProvider",
    "contribSourceControlInputBoxMenu",
    "languageModelThinkingPart"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "cliproxyapi",
        "displayName": "CLIProxyAPI"
      }
    ],
    "commands": [
      {
        "command": "modelProvider.manage",
        "title": "CLIProxyAPI: Manage Provider"
      },
      {
        "command": "modelProvider.configure",
        "title": "CLIProxyAPI: Configure Connection"
      },
      {
        "command": "modelProvider.importConfig",
        "title": "CLIProxyAPI: Import API Key from Config"
      },
      {
        "command": "modelProvider.refresh",
        "title": "CLIProxyAPI: Refresh Models"
      },
      {
        "command": "modelProvider.generateCommitMessage",
        "title": "CLIProxyAPI: Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "command": "modelProvider.selectCommitMessageModel",
        "title": "CLIProxyAPI: Select Commit Message Model"
      },
      {
        "command": "modelProvider.clearCredentials",
        "title": "CLIProxyAPI: Clear Stored API Key"
      },
      {
        "command": "modelProvider.showLogs",
        "title": "CLIProxyAPI: Show Logs"
      }
    ],
    "menus": {
      "scm/inputBox": [
        {
          "command": "modelProvider.generateCommitMessage",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "CLIProxyAPI Model Provider",
      "properties": {
        "modelProvider.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8317",
          "description": "Base URL of the CLIProxyAPI server."
        },
        "modelProvider.configPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to CLIProxyAPI config.yaml for credential and model metadata discovery."
        },
        "modelProvider.autoDetectConfig": {
          "type": "boolean",
          "default": true,
          "description": "Search common local CLIProxyAPI config locations when no config path is set."
        },
        "modelProvider.defaultMaxOutputTokens": {
          "type": "number",
          "default": 16384,
          "minimum": 1024,
          "description": "Fallback output-token limit when CLIProxyAPI provides no model-specific value."
        },
        "modelProvider.commitMessage.model": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Model ID used only for commit-message generation. Use the Select Commit Message Model command to choose from currently available models."
        },
        "modelProvider.commitMessage.instructions": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "editPresentation": "multilineText",
          "description": "Optional commit-message instructions. When empty, concise Conventional Commits are generated; when set, these instructions replace that style."
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --sourcemap",
    "prepare": "pnpm generate",
    "generate": "vscode-ext-gen --output src/generated/meta.ts",
    "vscode:dts": "dts main && dts dev",
    "lint": "eslint .",
    "test": "vitest run --project test:unit",
    "test:e2e": "vitest run --project test:e2e",
    "test:unit": "vitest run --project test:unit",
    "test:coverage": "vitest run --project test:unit --coverage",
    "test:watch": "vitest --project test:unit",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build",
    "vscode:prepublish": "pnpm build",
    "release": "bumpp",
    "ext:package": "vsce package --no-dependencies",
    "ext:publish": "vsxpub --no-dependencies"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21",
    "moderndash": "^4.0.2",
    "untildify": "^6.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vscode/dts": "^0.4.1",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "ovsx": "^1.0.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vscode-ext-gen": "^1.6.0",
    "vsxpub": "^0.1.4"
  }
}
